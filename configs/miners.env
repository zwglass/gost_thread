PEARL_MINERS_DIR=/home/youruser/programs/pearl_miners
MINER_IDS="lpminer alpha-miner wildrig pearlfortune peakminer srbminer tw-pearl-miner"

# Fixed-URL miners are installed only when missing. --update intentionally leaves
# them unchanged because their upstream sites do not expose GitHub Release tags.
LPMINER_SOURCE=fixed
LPMINER_DOWNLOAD_URL=https://pearl.luckypool.io/lpminer/lpminer-0.1.9.tar.gz
LPMINER_INSTALL_TYPE=archive-dir
LPMINER_BIN=${PEARL_MINERS_DIR}/lpminer/lpminer
LPMINER_WORKDIR=${PEARL_MINERS_DIR}/lpminer
LPMINER_BINARY_NAME=lpminer

ALPHA_MINER_SOURCE=fixed
ALPHA_MINER_DOWNLOAD_URL=https://pearl.alphapool.tech/downloads/alpha-miner
ALPHA_MINER_INSTALL_TYPE=binary
ALPHA_MINER_BIN=${PEARL_MINERS_DIR}/alpha_miner/alpha-miner
ALPHA_MINER_WORKDIR=${PEARL_MINERS_DIR}/alpha_miner
ALPHA_MINER_BINARY_NAME=alpha-miner

# GitHub miners resolve the latest stable Release only when they are missing or
# --update is supplied. Asset regexes deliberately select Linux builds only.
WILDRIG_SOURCE=github
WILDRIG_GITHUB_REPO=andru-kun/wildrig-multi
WILDRIG_ASSET_REGEX='^wildrig-multi-linux-[0-9]+\.[0-9]+\.[0-9]+\.tar\.gz$'
WILDRIG_INSTALL_TYPE=archive-dir
WILDRIG_BIN=${PEARL_MINERS_DIR}/wildrig/wildrig-multi
WILDRIG_WORKDIR=${PEARL_MINERS_DIR}/wildrig
WILDRIG_BINARY_NAME=wildrig-multi

PEARLFORTUNE_SOURCE=github
PEARLFORTUNE_GITHUB_REPO=pearlfortune/pearl-miner
PEARLFORTUNE_ASSET_REGEX='^pearlfortune-v[0-9]+\.[0-9]+\.[0-9]+\.tar\.gz$'
PEARLFORTUNE_INSTALL_TYPE=archive-dir
PEARLFORTUNE_BIN=${PEARL_MINERS_DIR}/pearlfortune/miner-cuda13
PEARLFORTUNE_WORKDIR=${PEARL_MINERS_DIR}/pearlfortune
PEARLFORTUNE_BINARY_NAME=miner-cuda13

PEAKMINER_SOURCE=github
PEAKMINER_GITHUB_REPO=peakminer/peakminer
PEAKMINER_ASSET_REGEX='^peakminer-[0-9]+\.[0-9]+\.[0-9]+\.tar\.gz$'
PEAKMINER_INSTALL_TYPE=archive-dir
PEAKMINER_BIN=${PEARL_MINERS_DIR}/peakminer/peakminer
PEAKMINER_WORKDIR=${PEARL_MINERS_DIR}/peakminer
PEAKMINER_BINARY_NAME=peakminer

SRBMINER_SOURCE=github
SRBMINER_GITHUB_REPO=doktor83/SRBMiner-Multi
SRBMINER_ASSET_REGEX='^SRBMiner-Multi-[0-9]+-[0-9]+-[0-9]+-Linux\.tar\.gz$'
SRBMINER_INSTALL_TYPE=archive-dir
SRBMINER_BIN=${PEARL_MINERS_DIR}/srbminer/SRBMiner-MULTI
SRBMINER_WORKDIR=${PEARL_MINERS_DIR}/srbminer
SRBMINER_BINARY_NAME=SRBMiner-MULTI

TW_PEARL_MINER_SOURCE=github
TW_PEARL_MINER_GITHUB_REPO=egg5233/tw-pearl-miner
# CUDA 12 Linux build. It supports NVIDIA driver >= 570.26 and excludes the
# Windows, B300, HiveOS, and MMPOS assets. To require CUDA 13 instead, use:
# TW_PEARL_MINER_ASSET_REGEX='^tw-pearl-miner-[0-9]+\.[0-9]+\.[0-9]+\.tar\.gz$'
TW_PEARL_MINER_ASSET_REGEX='^tw-pearl-miner-[0-9]+\.[0-9]+\.[0-9]+\.c12\.tar\.gz$'
TW_PEARL_MINER_INSTALL_TYPE=archive-dir
TW_PEARL_MINER_BIN=${PEARL_MINERS_DIR}/tw-pearl-miner/pearl-gpu-miner
TW_PEARL_MINER_WORKDIR=${PEARL_MINERS_DIR}/tw-pearl-miner
TW_PEARL_MINER_BINARY_NAME=pearl-gpu-miner
